---
config:
  theme: base
  themeVariables:
    background: "#ffffff"
    fontFamily: "Arial"
  flowchart:
    curve: basis
    htmlLabels: true
---
flowchart TB
    subgraph BASELINE["Before PR #7791"]
        direction LR
        B_REQUEST["Explicit request reuses<br/>observed cursor at group2"]:::risk --> B_ORDER["Evaluate group2 onward<br/>group1 is skipped"]:::risk
        B_ORDER --> B_STUCK["Recovered preferred cluster<br/>cannot be selected"]:::risk
    end

    subgraph SIXLINE["Initial six-line version"]
        direction LR
        S_REQUEST["Pending explicit<br/>request"]:::current --> S_RESET["Reset affinity cursor<br/>to term 0"]:::phase1
        S_RESET --> S_CACHE["Read informer-backed<br/>Cluster snapshot"]:::guard
        S_CACHE --> S_ORDER{"Has the informer observed<br/>the restored cluster?"}:::guard
        S_ORDER -->|yes| S_SUCCESS["group1 succeeds<br/>Binding returns to member1"]:::phase1
        S_ORDER -->|no| S_LOST["group1 fails, group2 succeeds<br/>one-shot request is consumed"]:::risk
    end

    subgraph CURRENT["Current PR #7791"]
        direction LR
        C_REQUEST["Pending explicit<br/>request"]:::current --> C_PREP["Reset cursor to term 0<br/>List Clusters with Most Recent consistency"]:::changed
        C_PREP -->|success| C_SNAPSHOT["Build one request-scoped snapshot<br/>Evaluate every term against it"]:::phase1
        C_SNAPSHOT --> C_PATCH["Patch final placement<br/>and complete request"]:::unchanged
        C_PREP -.->|API error| C_RETRY["Return error<br/>request remains pending"]:::failure
    end

    subgraph PHASE2["Later typed API and preserve-available behavior"]
        direction TB
        P_WR["WorkloadRebalancer<br/>optional behavior"]:::unchanged --> P_TYPED["Typed Binding request<br/>triggeredAt + behavior"]:::phase2
        P_LEGACY["Deprecated timestamp<br/>still accepted"]:::unchanged --> P_LATEST{"Choose latest request<br/>new wins legacy ties"}:::phase2
        P_TYPED --> P_LATEST
        P_LATEST -->|Full, nil, or false| P_FULL["Use the current Full<br/>rescheduling path"]:::phase1
        P_LATEST -->|PreserveAvailableReplicas=true| P_STATUS["Read Deployment<br/>availableReplicas snapshot"]:::phase2
        P_STATUS --> P_GUARD{"Status and policy<br/>contract satisfied?"}:::guard
        P_GUARD -->|yes| P_BASE["Pin available replicas<br/>as an in-memory baseline"]:::phase2
        P_BASE --> P_DELTA["Allocate only the<br/>unavailable replica delta"]:::phase2
        P_GUARD -->|no| P_FAIL["Fail closed<br/>do not change placement"]:::failure
        P_DELTA --> P_FINAL["Patch final<br/>spec.clusters once"]:::unchanged
    end

    B_STUCK ~~~ S_REQUEST
    S_SUCCESS ~~~ C_REQUEST
    C_PATCH ~~~ P_WR

    OUT["Out of scope<br/>SafeMigration, automatic waterline,<br/>cancel, rollback, progress"]:::out
    PHASE2 -.-> OUT

    classDef current fill:#f5f5f5,stroke:#666666,color:#262626;
    classDef unchanged fill:#dae8fc,stroke:#6c8ebf,color:#172554;
    classDef phase1 fill:#d5e8d4,stroke:#38761d,color:#14532d,stroke-width:2px;
    classDef changed fill:#e1d5e7,stroke:#9673a6,color:#4a235a,stroke-width:2px;
    classDef phase2 fill:#d9ead3,stroke:#0f766e,color:#134e4a,stroke-width:2px;
    classDef guard fill:#fff2cc,stroke:#d6b656,color:#713f12,stroke-width:2px;
    classDef risk fill:#f8cecc,stroke:#b85450,color:#7f1d1d,stroke-width:2px;
    classDef failure fill:#f8cecc,stroke:#b85450,color:#7f1d1d,stroke-dasharray:6 4;
    classDef out fill:#ffffff,stroke:#777777,color:#404040,stroke-dasharray:5 5;
