    classDef bridge fill:#dae8fc,stroke:#82b366,color:#14532d,stroke-width:3px;
    classDef shared fill:#fff2cc,stroke:#d6b656,color:#713f12;
    classDef risk fill:#f8cecc,stroke:#b85450,color:#7f1d1d,stroke-width:2px,stroke-dasharray:6 4;
    classDef note fill:#ffffff,stroke:#2563eb,color:#172554,stroke-width:2px;
    classDef legend fill:#ffffff,stroke:#9ca3af,color:#374151,fontSize:12px;

    class TITLE title;
    class OPS,DECIDE external;
    class APP,API,DET,SCHED,BC,EXEC,SOURCE,TARGET,REFLECT current;
    class LIFE,ROUTER,RES,SAFE,UNIT proposed;
    class WRC bridge;
    class WR,RB,WORK shared;
    class RISK risk;
    class POSITION note;
    class LEGEND legend;
